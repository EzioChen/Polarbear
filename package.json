{
    "publisher": "eziochan",
    "name": "pubflow",
    "displayName": "pubFlow",
    "description": "适用于 JL 发布测试版本的打包发布流",
    "version": "0.0.2",
    "repository": {
        "type": "git",
        "url": "https://github.com/EzioChen/Polarbear.git"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "polarbear.startPolar",
                "title": "Start Polar",
                "icon": "$(play)"
            },
            {
                "command": "polarbear.testLogin",
                "title": "Test Login",
                "icon": "$(account)"
            },
            {
                "command": "polarbear.openSettings",
                "title": "Open Settings",
                "icon": "$(gear)"
            },
            {
                "command": "polarbear.addPublishFlow",
                "title": "Add Publish Flow",
                "icon": "$(add)"
            },
            {
                "command": "polarbear.openPublishFlow",
                "title": "Open Publish Flow",
                "icon": "$(gear)"
            },
            {
                "command": "polarbear.openReleaseNotes",
                "title": "Open Release Notes",
                "icon": "$(book)"
            },
            {
                "command": "polarbear.openPublishTimeline",
                "title": "Open Publish Timeline",
                "icon": "$(play)"
            },
            {
                "command": "polarbear.email.openEditor",
                "title": "打开邮件编辑器",
                "category": "PolarBear Email",
                "icon": "$(mail)"
            },
            {
                "command": "polarbear.email.configure",
                "title": "配置邮件服务",
                "category": "PolarBear Email",
                "icon": "$(gear)"
            },
            {
                "command": "polarbear.email.testConnection",
                "title": "测试 SMTP 连接",
                "category": "PolarBear Email",
                "icon": "$(plug)"
            },
            {
                "command": "polarbear.email.validateConfig",
                "title": "验证邮件配置",
                "category": "PolarBear Email",
                "icon": "$(check)"
            },
            {
                "command": "polarbear.email.reloadConfig",
                "title": "重新加载配置",
                "category": "PolarBear Email",
                "icon": "$(refresh)"
            },
            {
                "command": "polarbear.email.sendQuick",
                "title": "快速发送邮件",
                "category": "PolarBear Email",
                "icon": "$(send)"
            },
            {
                "command": "polarbear.email.showLogs",
                "title": "查看邮件日志",
                "category": "PolarBear Email",
                "icon": "$(output)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "polarbearContainer",
                    "title": "PolarBear",
                    "icon": "resources/bear_icon.png"
                }
            ]
        },
        "views": {
            "polarbearContainer": [
                {
                    "id": "polarbearView",
                    "name": "发布工具",
                    "type": "tree"
                }
            ]
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "polarbear.email.openEditor",
                    "category": "PolarBear Email"
                },
                {
                    "command": "polarbear.email.configure",
                    "category": "PolarBear Email"
                },
                {
                    "command": "polarbear.email.testConnection",
                    "category": "PolarBear Email"
                },
                {
                    "command": "polarbear.email.validateConfig",
                    "category": "PolarBear Email"
                },
                {
                    "command": "polarbear.email.reloadConfig",
                    "category": "PolarBear Email"
                },
                {
                "command": "polarbear.email.showLogs",
                "category": "PolarBear Email"
            }
        ]
    },
    "configuration": {
        "title": "PolarBear Email",
        "properties": {
            "polarbear.email.smtp.host": {
                "type": "string",
                "default": "",
                "description": "SMTP 服务器地址"
            },
            "polarbear.email.smtp.port": {
                "type": "number",
                "default": 25,
                "description": "SMTP 服务器端口"
            },
            "polarbear.email.smtp.secure": {
                "type": "boolean",
                "default": false,
                "description": "是否使用 SSL/TLS 加密连接"
            },
            "polarbear.email.smtp.tls.rejectUnauthorized": {
                "type": "boolean",
                "default": false,
                "description": "是否拒绝未授权证书"
            },
            "polarbear.email.smtp.tls.minVersion": {
                "type": "string",
                "default": "TLSv1.2",
                "description": "最小 TLS 版本"
            },
            "polarbear.email.auth.type": {
                "type": "string",
                "default": "login",
                "enum": ["login", "oauth2"],
                "description": "认证类型"
            },
            "polarbear.email.auth.user": {
                "type": "string",
                "default": "",
                "description": "SMTP 用户名/邮箱地址"
            },
            "polarbear.email.sender.name": {
                "type": "string",
                "default": "",
                "description": "发件人显示名称"
            },
            "polarbear.email.sender.address": {
                "type": "string",
                "default": "",
                "description": "发件人邮箱地址"
            },
            "polarbear.email.connection.timeout": {
                "type": "number",
                "default": 30000,
                "description": "连接超时时间（毫秒）"
            },
            "polarbear.email.retry.enabled": {
                "type": "boolean",
                "default": true,
                "description": "启用自动重试"
            },
            "polarbear.email.retry.maxRetries": {
                "type": "number",
                "default": 3,
                "description": "最大重试次数"
            },
            "polarbear.email.defaultTo": {
                "type": "array",
                "default": [],
                "description": "默认收件人列表"
            },
            "polarbear.email.defaultCc": {
                "type": "array",
                "default": [],
                "description": "默认抄送列表"
            },
            "polarbear.email.logging.enabled": {
                "type": "boolean",
                "default": true,
                "description": "启用日志记录"
            },
            "polarbear.email.logging.level": {
                "type": "string",
                "default": "info",
                "enum": ["debug", "info", "warn", "error"],
                "description": "日志级别"
            }
        }
    },
    "keybindings": [
            {
                "command": "polarbear.email.openEditor",
                "key": "ctrl+shift+m",
                "mac": "cmd+shift+m",
                "when": "editorTextFocus"
            },
            {
                "command": "polarbear.email.sendQuick",
                "key": "ctrl+shift+enter",
                "mac": "cmd+shift+enter",
                "when": "editorTextFocus"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "build:webview": "cd webview && npm run build",
        "compile": "npm run build:webview && webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/nodemailer": "^8.0.0",
        "@types/vscode": "^1.74.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "copy-webpack-plugin": "^14.0.0",
        "eslint": "^9.39.3",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "webpack": "^5.105.3",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@types/jszip": "^3.4.0",
        "jszip": "^3.10.1",
        "nodemailer": "^8.0.7"
    },
    "license": "MIT"
}