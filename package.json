{
  "name": "polarbear",
  "displayName": "polarbear",
  "description": "一个流程发布工具",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "polarbear.startPolar",
        "title": "Start Polar",
        "icon": "$(play)"
      },
      {
        "command": "polarbear.testLogin",
        "title": "Test Login",
        "icon": "$(account)"
      },
      {
        "command": "polarbear.openSettings",
        "title": "Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "polarbear.addPublishFlow",
        "title": "Add Publish Flow",
        "icon": "$(add)"
      },
      {
        "command": "polarbear.openPublishFlow",
        "title": "Open Publish Flow",
        "icon": "$(gear)"
      },
      {
        "command": "polarbear.openReleaseNotes",
        "title": "Open Release Notes",
        "icon": "$(book)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "polarbearContainer",
          "title": "PolarBear",
          "icon": "resources/bear_icon.png"
        }
      ]
    },
    "views": {
      "polarbearContainer": [
        {
          "id": "polarbearView",
          "name": "发布工具",
          "type": "tree"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webview": "cd webview && npm run build",
    "compile": "npm run build:webview && webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
